rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { allow read, write: if false; }
    
    function isValidId(id) { 
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      // Bootstrap the original admin or lookup from DB if exists
      return isSignedIn() && (request.auth.token.email == 'bheshdadiya@gmail.com' || existing().isAdmin == true || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true);
    }
    
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'name', 'freeUses', 'isSubscribed', 'isAdmin', 'createdAt', 'updatedAt']) 
        && data.email is string && data.email.size() <= 200
        && data.name is string && data.name.size() <= 100
        && data.freeUses is number
        && data.isSubscribed is bool
        && data.isAdmin is bool
        && data.createdAt is timestamp
        && data.updatedAt is timestamp
        // Optional fields
        && (data.keys().hasAny(['photo']) ? (data.photo is string && data.photo.size() <= 1000) : true)
        && (data.keys().hasAny(['mobile']) ? (data.mobile is string && data.mobile.size() <= 20) : true)
        && (data.keys().hasAny(['lastFreeUseAt']) ? data.lastFreeUseAt is number : true)
        && (data.keys().hasAny(['subscriptionExpiresAt']) ? data.subscriptionExpiresAt is number : true);
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() 
        && isValidId(userId)
        && request.auth.uid == userId
        && request.auth.token.email_verified == true
        && isValidUser(incoming())
        && incoming().email == request.auth.token.email
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time
        && (!incoming().isAdmin || request.auth.token.email == 'bheshdadiya@gmail.com');
      allow update: if isSignedIn() 
        && isValidId(userId)
        && isValidUser(incoming())
        && incoming().updatedAt == request.time
        && incoming().createdAt == existing().createdAt
        && incoming().email == existing().email
        && (
          isAdmin() || 
          (request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'photo', 'mobile', 'freeUses', 'lastFreeUseAt', 'updatedAt']) && incoming().isAdmin == existing().isAdmin && incoming().isSubscribed == existing().isSubscribed)
        );
      allow list: if isAdmin();
    }
    
    function isValidPost(data) {
      return data.keys().hasAll(['title', 'content', 'authorId', 'createdAt', 'updatedAt'])
        && data.title is string && data.title.size() <= 200
        && data.content is string && data.content.size() <= 50000
        && data.authorId is string && data.authorId.size() <= 128
        && data.createdAt is timestamp
        && data.updatedAt is timestamp
        && (data.keys().hasAny(['imageUrl']) ? (data.imageUrl is string && data.imageUrl.size() <= 2000) : true);
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if isAdmin() 
        && isValidId(postId)
        && isValidPost(incoming())
        && incoming().authorId == request.auth.uid
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
      allow update: if isAdmin() 
        && isValidId(postId)
        && isValidPost(incoming())
        && incoming().updatedAt == request.time
        && incoming().createdAt == existing().createdAt
        && incoming().authorId == existing().authorId;
      allow delete: if isAdmin();
      allow list: if true;
    }

    function isValidReport(data) {
      return data.keys().hasAll(['reporterId', 'reason', 'createdAt', 'status'])
        && data.reporterId is string && data.reporterId.size() <= 128
        && data.reason is string && data.reason.size() <= 500
        && data.status in ['pending', 'reviewed', 'resolved']
        && data.createdAt is timestamp
        && (data.keys().hasAny(['contentId']) ? (data.contentId is string && data.contentId.size() <= 128) : true)
        && (data.keys().hasAny(['contentType']) ? (data.contentType is string && data.contentType.size() <= 50) : true)
        && (data.keys().hasAny(['details']) ? (data.details is string && data.details.size() <= 2000) : true);
    }

    match /reports/{reportId} {
      allow create: if isSignedIn() 
        && isValidId(reportId)
        && incoming().reporterId == request.auth.uid
        && incoming().status == 'pending'
        && incoming().createdAt == request.time
        && isValidReport(incoming());
      allow read, list, update, delete: if isAdmin();
    }

    function isValidSignal(data) {
      return data.keys().hasAll(['userId', 'userName', 'instrument', 'timeframe', 'analysis', 'status', 'createdAt'])
        && data.userId is string && data.userId.size() <= 128
        && data.userName is string && data.userName.size() <= 100
        && data.instrument is string && data.instrument.size() <= 50
        && data.timeframe is string && data.timeframe.size() <= 20
        && data.analysis is map
        && data.status in ['active', 'tp_hit', 'sl_hit', 'closed']
        && data.createdAt is timestamp
        && (data.keys().hasAny(['feedback']) ? (data.feedback in ['accurate', 'inaccurate']) : true);
    }

    match /signals/{signalId} {
      allow create: if isSignedIn()
        && incoming().userId == request.auth.uid
        && incoming().status == 'active'
        && incoming().createdAt == request.time
        && isValidSignal(incoming());
      
      allow read: if isSignedIn() && (request.auth.uid == resource.data.userId || isAdmin());
      allow list: if isAdmin();
      
      allow update: if (isAdmin() 
        && incoming().diff(existing()).affectedKeys().hasOnly(['status'])
        && incoming().status in ['active', 'tp_hit', 'sl_hit', 'closed'])
        ||
        (isSignedIn() && existing().userId == request.auth.uid 
        && incoming().diff(existing()).affectedKeys().hasOnly(['feedback'])
        && incoming().feedback in ['accurate', 'inaccurate']);
      allow delete: if isAdmin();
    }
    function isValidSupportQuery(data) {
      return data.keys().hasAll(['userId', 'email', 'name', 'query', 'status', 'createdAt', 'updatedAt'])
        && data.userId is string && data.userId.size() <= 128
        && data.email is string && data.email.size() <= 200
        && data.name is string && data.name.size() <= 100
        && data.query is string && data.query.size() <= 5000
        && data.status in ['open', 'closed']
        && data.createdAt is timestamp
        && data.updatedAt is timestamp
        && (data.keys().hasAny(['mobile']) ? (data.mobile is string && data.mobile.size() <= 20) : true)
        && (data.keys().hasAny(['response']) ? (data.response is string && data.response.size() <= 5000) : true);
    }

    match /support_queries/{queryId} {
      allow create: if isSignedIn()
        && isValidId(queryId)
        && incoming().userId == request.auth.uid
        && incoming().status == 'open'
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time
        && isValidSupportQuery(incoming());
      allow update: if (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['response', 'status', 'updatedAt']) && incoming().updatedAt == request.time)
        || (isSignedIn() && existing().userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['query', 'updatedAt']) && incoming().updatedAt == request.time);
      allow read: if isSignedIn() && (request.auth.uid == resource.data.userId || isAdmin());
      allow list: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
