{
  "entities": {
    "user": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "name": { "type": "string" },
        "photo": { "type": "string" },
        "mobile": { "type": "string" },
        "freeUses": { "type": "number" },
        "isSubscribed": { "type": "boolean" },
        "planId": { "type": "string" },
        "isAdmin": { "type": "boolean" },
        "lastFreeUseAt": { "type": "number" },
        "subscriptionExpiresAt": { "type": "number" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["email", "name", "freeUses", "isSubscribed", "isAdmin", "createdAt", "updatedAt"]
    },
    "post": {
      "title": "Blog Post",
      "description": "Educational blog posts",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "authorId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["title", "content", "authorId", "createdAt", "updatedAt"]
    },
    "report": {
      "title": "Content Report",
      "description": "User reports for objectionable content",
      "type": "object",
      "properties": {
        "reporterId": { "type": "string" },
        "contentId": { "type": "string" },
        "contentType": { "type": "string" },
        "reason": { "type": "string" },
        "details": { "type": "string" },
        "createdAt": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "reviewed", "resolved"] }
      },
      "required": ["reporterId", "reason", "createdAt", "status"]
    },
    "support_query": {
      "title": "Customer Support Query",
      "description": "Queries submitted via the chatbot",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "mobile": { "type": "string" },
        "query": { "type": "string" },
        "response": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "closed"] },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["userId", "email", "name", "query", "status", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/user" },
      "description": "Stores user profiles"
    },
    "posts/{postId}": {
      "schema": { "$ref": "#/entities/post" },
      "description": "Stores blog posts created by admins"
    },
    "reports/{reportId}": {
      "schema": { "$ref": "#/entities/report" },
      "description": "Stores content reports"
    },
    "support_queries/{queryId}": {
      "schema": { "$ref": "#/entities/support_query" },
      "description": "Stores support queries from the chatbot"
    }
  }
}
